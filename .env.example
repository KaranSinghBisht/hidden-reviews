# hidden.reviews — environment

# Nimble: live web data (search + extract across Reddit / Trustpilot / forums).
# Free trial + hackathon credits: https://online.nimbleway.com/signup
NIMBLE_API_KEY=

# Anthropic: Claude synthesis of the honest verdict.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: force canned/mock data even when keys are present.
# Set to 1 for a 100% reliable, instant demo. Leave empty for live mode.
HIDDEN_REVIEWS_FORCE_MOCK=
